@{
    ViewBag.Title = "Sign In";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>@ViewBag.Title — InsurePro Agency</title>
    <link rel="stylesheet" href="~/css/ims-green.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@2.47.0/tabler-icons.min.css"/>
</head>
<body class="login-body">

<div class="login-wrap">

    <!-- ══ LEFT PANEL — Branding ══ -->
    <div class="lp">
        <div class="lp-grid"></div>
        <div class="lp-glow"></div>
        <div class="lp-glow2"></div>

        <!-- Redesigned Shield SVG Logo -->
        <div class="logo-scene">
            <svg width="180" height="180" viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="InsurePro Agency Shield Logo">
                <circle cx="90" cy="90" r="82" stroke="rgba(34,197,94,0.15)" stroke-width="1"/>
                <circle cx="90" cy="90" r="68" stroke="rgba(34,197,94,0.1)" stroke-width="0.5"/>
                <circle cx="90" cy="8"   r="4" fill="#22c55e" opacity=".5"/>
                <circle cx="172" cy="90" r="3" fill="#4ade80" opacity=".3"/>
                <circle cx="8"   cy="90" r="3" fill="#4ade80" opacity=".3"/>
                <circle cx="90" cy="172" r="4" fill="#22c55e" opacity=".4"/>
                <path d="M90 28L48 46V84C48 112 66 134 90 142C114 134 132 112 132 84V46L90 28Z"
                      fill="#064e3b" stroke="#166534" stroke-width="1"/>
                <path d="M90 38L56 53V84C56 108 71 127 90 134C109 127 124 108 124 84V53L90 38Z"
                      fill="rgba(34,197,94,0.08)" stroke="rgba(34,197,94,0.2)" stroke-width="0.5"/>
                <polyline points="74,88 84,99 108,74"
                          stroke="#22c55e" stroke-width="5"
                          stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                <rect x="60" y="118" width="60" height="18" rx="9"
                      fill="rgba(22,163,74,0.2)" stroke="rgba(34,197,94,0.3)" stroke-width="0.5"/>
                <text x="90" y="130" text-anchor="middle"
                      font-family="'Segoe UI',sans-serif" font-size="9" font-weight="700"
                      fill="#86efac" letter-spacing="1">INSURED</text>
                <circle cx="90" cy="38" r="3" fill="#22c55e" opacity=".8"/>
            </svg>
        </div>

        <div class="lp-text">
            <div class="lp-eyebrow">
                <i class="ti ti-shield-check"></i> Trusted Since 2008
            </div>
            <h1 class="lp-title">Insurance <em>Management</em><br/>System</h1>
            <p class="lp-sub">Complete agency platform for policies, claims, agents and renewals — all in one place.</p>
            <div class="pills">
                <span class="pill"><span class="pill-dot"></span>Motor</span>
                <span class="pill"><span class="pill-dot"></span>Life</span>
                <span class="pill"><span class="pill-dot"></span>Medical</span>
                <span class="pill"><span class="pill-dot"></span>Fire</span>
                <span class="pill"><span class="pill-dot"></span>Marine</span>
            </div>
            <div class="lp-stats">
                <div class="stat"><span class="stat-n">99%</span><span class="stat-l">Claims settled</span></div>
                <div class="stat"><span class="stat-n">24/7</span><span class="stat-l">Support</span></div>
                <div class="stat"><span class="stat-n">MY</span><span class="stat-l">Licensed</span></div>
            </div>
        </div>
    </div>

    <!-- ══ RIGHT PANEL — Login Form ══ -->
    <div class="rp">
        <div class="sys-badge"><div class="sys-dot"></div>System Online</div>

        <div class="login-form-inner">
            <div class="fhead">
                <div class="feyebrow"><div class="fline"></div><span>Secure Portal</span></div>
                <h2 class="ftitle">Welcome <span>Back</span></h2>
                <p class="fsub">Sign in to access the Insurance Agency Management system.</p>
            </div>

                @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { @class = "login-form" }))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new { @class = "alert-danger" })

                <div class="fg">
                    <label class="fl"><i class="ti ti-user"></i> Username</label>
                    <div class="fi-wrap">
                        <span class="fi-icon"><i class="ti ti-user"></i></span>
                        @Html.TextBox("UserName", "", new { @class = "fi", placeholder = "Enter your username", autocomplete = "username" })
                        @Html.ValidationMessage("UserName", "", new { @class = "field-error" })
                    </div>
                </div>

                <div class="fg">
                    <label class="fl"><i class="ti ti-lock"></i> Password</label>
                    <div class="fi-wrap">
                        <span class="fi-icon"><i class="ti ti-lock"></i></span>
                        @Html.Password("Password", "", new { @class = "fi", placeholder = "Enter your password", autocomplete = "current-password" })
                        <button type="button" class="eye-toggle" onclick="togglePwd(this)" aria-label="Toggle password visibility">
                            <i class="ti ti-eye"></i>
                        </button>
                        @Html.ValidationMessage("Password", "", new { @class = "field-error" })
                    </div>
                </div>

                <div class="row-opts">
                    <label class="rem-me">
                        @Html.CheckBox("RememberMe") Remember me 8 hrs
                    </label>
                        @Html.ActionLink("Forgot password?", "ForgotPassword", "Account", null, new { @class = "fp-link" })
                </div>

                <button type="submit" class="btn-login">
                    <i class="ti ti-login"></i> Sign In
                </button>
            }

            <div class="ffoot">
                <p>Need help? Contact your <strong>system administrator</strong>.</p>
                <p class="copy">© @DateTime.Now.Year InsurePro Agency &nbsp;·&nbsp; v2.0.1</p>
            </div>
        </div>
    </div>

</div>

<script>
function togglePwd(btn) {
    var fi = btn.closest('.fi-wrap').querySelector('input');
    var icon = btn.querySelector('i');
    if (fi.type === 'password') {
        fi.type = 'text';
        icon.className = 'ti ti-eye-off';
    } else {
        fi.type = 'password';
        icon.className = 'ti ti-eye';
    }
}
</script>
</body>
</html>
