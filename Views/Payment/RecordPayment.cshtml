@model ImsAgency.Web.Models.ViewModels.RecordPaymentViewModel
@using Microsoft.AspNetCore.Html
@{
    ViewData["Title"] = "Record Payment";
    Func<string, string, IHtmlContent> Sel = (val, match) =>
        val == match ? new HtmlString("selected=\"selected\"") : HtmlString.Empty;
}

<div class="page-header">
    <div>
        <h1 class="page-title">Record Payment</h1>
        <p class="page-subtitle">Record a premium payment from a client</p>
    </div>
    <div>
        <a href="@Url.Action("AllPayments")" class="btn-ptc-outline">
            <i class="bi bi-arrow-left"></i> Back to Payments
        </a>
    </div>
</div>

@Html.AntiForgeryToken()

<div style="display:grid; grid-template-columns:1.4fr 1fr; gap:16px;">

    <!-- LEFT: PAYMENT FORM -->
    <div class="ptc-card">
        <div class="ptc-card-header">
            <h2 class="ptc-card-title">Payment Details</h2>
        </div>
        <div class="ptc-card-body">
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

                <!-- CLIENT SEARCH -->
                <div style="grid-column:span 2;">
                    <label class="form-label">
                        Client <span class="text-danger">*</span>
                    </label>
                    <input type="text" id="clientCombo" style="width:100%;" />
                </div>

                <!-- POLICY PICKER -->
                <div style="grid-column:span 2;">
                    <label class="form-label">
                        Policy <span class="text-danger">*</span>
                    </label>
                    <select id="PolicyId" class="form-select">
                        <option value="0">— Select client first —</option>
                    </select>
                    <small class="text-muted">
                        Only Active / Quoted / Draft policies are shown
                    </small>
                </div>

                <!-- PAYMENT DATE -->
                <div>
                    <label class="form-label">
                        Payment Date <span class="text-danger">*</span>
                    </label>
                    <input type="date" id="PaymentDate" class="form-control"
                           value="@Model.PaymentDate.ToString("yyyy-MM-dd")" />
                </div>

                <!-- PAYMENT METHOD -->
                <div>
                    <label class="form-label">
                        Payment Method <span class="text-danger">*</span>
                    </label>
                    <select id="PaymentMethod" class="form-select">
                        <option value="Cash"        @Sel(Model.PaymentMethod,"Cash")>Cash</option>
                        <option value="Cheque"      @Sel(Model.PaymentMethod,"Cheque")>Cheque</option>
                        <option value="FPX"         @Sel(Model.PaymentMethod,"FPX")>FPX</option>
                        <option value="CreditCard"  @Sel(Model.PaymentMethod,"CreditCard")>Credit Card</option>
                        <option value="DuitNowQR"   @Sel(Model.PaymentMethod,"DuitNowQR")>DuitNow QR</option>
                    </select>
                </div>

                <!-- AMOUNT -->
                <div>
                    <label class="form-label">
                        Amount Paid (RM) <span class="text-danger">*</span>
                    </label>
                    <input type="number" id="AmountPaid" class="form-control"
                           value="@Model.AmountPaid" min="0.01" step="0.01"
                           placeholder="0.00" />
                </div>

                <!-- BANK / ISSUER -->
                <div id="bankGroup">
                    <label class="form-label">Bank / Issuer</label>
                    <input type="text" id="BankOrIssueName" class="form-control"
                           value="@Model.BankOrIssueName"
                           placeholder="e.g. Maybank, CIMB" />
                </div>

                <!-- REFERENCE NUMBER -->
                <div>
                    <label class="form-label">Reference Number</label>
                    <input type="text" id="ReferenceNumber" class="form-control"
                           value="@Model.ReferenceNumber"
                           placeholder="Cheque No. / FPX Ref / Gateway ID" />
                </div>

                <!-- CLEARED -->
                <div>
                    <label class="form-label">Cleared & Settled</label>
                    <select id="IsClearedAndSettled" class="form-select">
                        <option value="true"  @Sel(Model.IsClearedAndSettled.ToString().ToLower(),"true")>
                            Yes — Cleared
                        </option>
                        <option value="false" @Sel(Model.IsClearedAndSettled.ToString().ToLower(),"false")>
                            No — Pending Clearance
                        </option>
                    </select>
                </div>

                <!-- REMARKS -->
                <div style="grid-column:span 2;">
                    <label class="form-label">Remarks</label>
                    <textarea id="Remarks" class="form-control" rows="2">@Model.Remarks</textarea>
                </div>

            </div>

            <div class="mt-3">
                <button type="button" id="btnSavePayment" class="btn-ptc-primary">
                    <i class="bi bi-save"></i> Record Payment
                </button>
            </div>
        </div>
    </div>

    <!-- RIGHT: POLICY BALANCE SUMMARY -->
    <div class="ptc-card">
        <div class="ptc-card-header">
            <h2 class="ptc-card-title">
                <i class="bi bi-receipt"></i> Policy Balance
            </h2>
        </div>
        <div class="ptc-card-body" id="balanceSummary">
            <p class="text-muted">
                Select a client and policy to see the outstanding balance.
            </p>
        </div>
    </div>

</div>

@section Scripts {
<script>
    $(document).ready(function () {

        // ============================================================
        // CLIENT COMBOBOX (remote search)
        // ============================================================
        var clientCombo = $("#clientCombo").kendoComboBox({
            dataTextField  : "Text",
            dataValueField : "Id",
            filter         : "contains",
            minLength      : 1,
            autoBind       : false,
            placeholder    : "Type client name, code, or NRIC/BRN...",
            dataSource: {
                serverFiltering: true,
                transport: {
                    read: {
                        url      : '@Url.Action("SearchClients","Policy")',
                        dataType : "json"
                    }
                }
            }
        }).data("kendoComboBox");

        // When client is selected, load their policies
        clientCombo.bind("change", function () {
            var clientId = this.value();
            if (!clientId) { resetPolicyPicker(); return; }

            $.get('@Url.Action("SearchClientPolicies","Payment")',
                { clientId: clientId })
            .done(function (policies) {
                var select = $('#PolicyId');
                select.empty().append('<option value="0">— Select Policy —</option>');

                if (!policies || policies.length === 0) {
                    select.append('<option value="0" disabled>No active policies found</option>');
                    updateBalanceSummary(null);
                    return;
                }

                $.each(policies, function (i, p) {
                    select.append($('<option>', {
                        value: p.Id,
                        text : p.Text,
                        'data-net'  : p.NetPremiumPayable,
                        'data-paid' : p.TotalPaid
                    }));
                });

                // Auto-select first policy and show balance
                select.trigger('change');
            });
        });

        // Policy dropdown change → update balance summary + auto-fill amount
        $('#PolicyId').on('change', function () {
            var selected = $(this).find('option:selected');
            var net  = parseFloat(selected.data('net'))  || 0;
            var paid = parseFloat(selected.data('paid')) || 0;
            var bal  = Math.max(0, net - paid);

            if ($(this).val() === '0') {
                updateBalanceSummary(null);
                return;
            }

            updateBalanceSummary({ net: net, paid: paid, balance: bal });

            // Auto-fill amount with outstanding balance (agent can override)
            if (bal > 0) {
                $('#AmountPaid').val(bal.toFixed(2));
            }
        });

        function resetPolicyPicker() {
            $('#PolicyId').empty().append('<option value="0">— Select client first —</option>');
            updateBalanceSummary(null);
        }

        function updateBalanceSummary(data) {
            if (!data) {
                $('#balanceSummary').html(
                    '<p class="text-muted">Select a client and policy to see the outstanding balance.</p>');
                return;
            }

            var balanceColor = data.balance > 0 ? 'var(--ims-danger)' : 'var(--ims-accent)';
            var balanceLabel = data.balance > 0 ? 'Outstanding' : 'Fully Paid';

            $('#balanceSummary').html(
                '<table class="table table-sm mb-3">'
              + '<tr><td>Net Premium Payable</td>'
              + '<td class="text-end fw-semibold">RM ' + data.net.toFixed(2) + '</td></tr>'
              + '<tr><td>Total Paid So Far</td>'
              + '<td class="text-end text-success fw-semibold">RM ' + data.paid.toFixed(2) + '</td></tr>'
              + '</table>'
              + '<div class="d-flex justify-content-between align-items-center p-3 rounded" '
              + 'style="background:' + balanceColor + '1A; border:1px solid ' + balanceColor + ';">'
              + '<span style="font-weight:700; color:' + balanceColor + ';">' + balanceLabel + '</span>'
              + '<span style="font-size:22px; font-weight:800; color:' + balanceColor + ';">'
              + 'RM ' + data.balance.toFixed(2) + '</span></div>'
            );
        }

        // ============================================================
        // SAVE PAYMENT
        // ============================================================
        $('#btnSavePayment').on('click', function () {
            var clientId  = clientCombo.value();
            var policyId  = $('#PolicyId').val();
            var amount    = parseFloat($('#AmountPaid').val()) || 0;

            if (!clientId || parseInt(clientId) === 0) {
                KSwal.warning('Please select a client.'); return; }
            if (!policyId || policyId === '0') {
                KSwal.warning('Please select a policy.'); return; }
            if (amount <= 0) {
                KSwal.warning('Please enter the amount paid.'); return; }

            var payload = {
                ClientId          : clientId,
                PolicyId          : policyId,
                PaymentDate       : $('#PaymentDate').val(),
                PaymentMethod     : $('#PaymentMethod').val(),
                AmountPaid        : amount,
                BankOrIssueName   : $('#BankOrIssueName').val(),
                ReferenceNumber   : $('#ReferenceNumber').val(),
                IsClearedAndSettled: $('#IsClearedAndSettled').val(),
                Remarks           : $('#Remarks').val(),
                __RequestVerificationToken:
                    $('input[name="__RequestVerificationToken"]').val()
            };

            $.post('@Url.Action("SavePayment","Payment")', payload)
                .done(function (res) {
                    if (res.success) {
                        KSwal.success(res.message + '\nReceipt: ' + res.receiptNumber)
                            .then(function () {
                                window.location.href = '@Url.Action("AllPayments")';
                            });
                    } else {
                        KSwal.error(res.message);
                    }
                })
                .fail(function () {
                    KSwal.error('An unexpected error occurred.');
                });
        });

    });
</script>
}