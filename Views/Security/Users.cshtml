@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <div>
        <h1 class="page-title">User Management</h1>
        <p class="page-subtitle">Manage login accounts and role assignments</p>
    </div>
    <div>
        <button type="button" id="btnNewUser" class="btn-ptc-primary">
            <i class="bi bi-person-plus"></i> Create User
        </button>
    </div>
</div>

<!-- FILTER -->
<div class="ptc-card mb-3">
    <div class="ptc-card-body">
        <div style="display:grid; grid-template-columns:3fr auto auto; gap:12px; align-items:end;">
            <div>
                <label class="form-label">Search</label>
                <input type="text" id="filterSearchText" class="form-control"
                       placeholder="Username, Full Name, or Email" />
            </div>
            <div>
                <button type="button" id="btnSearch" class="btn-ptc-primary">
                    <i class="bi bi-search"></i> Search
                </button>
            </div>
            <div>
                <button type="button" id="btnClearFilter" class="btn-ptc-outline">
                    <i class="bi bi-x-circle"></i> Clear
                </button>
            </div>
        </div>
    </div>
</div>

<!-- GRID -->
<div class="ptc-card">
    <div class="ptc-card-header">
        <h2 class="ptc-card-title">User Accounts</h2>
        <span id="recordCount" class="record-count-badge">0 records</span>
    </div>
    <div class="ptc-card-body" style="padding:0;">
        <div id="user_grid"></div>
    </div>
</div>

<!-- CREATE USER MODAL -->
<div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus"></i> Create New User
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
                    <div>
                        <label class="form-label">Username <span class="text-danger">*</span></label>
                        <input type="text" id="cu_Username" class="form-control"
                               placeholder="e.g. ahmad.ibrahim" />
                    </div>
                    <div>
                        <label class="form-label">Full Name <span class="text-danger">*</span></label>
                        <input type="text" id="cu_FullName" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" id="cu_Email" class="form-control" />
                    </div>
                    <div>
                        <label class="form-label">Password <span class="text-danger">*</span></label>
                        <input type="password" id="cu_Password" class="form-control"
                               placeholder="Minimum 8 characters" />
                    </div>
                    <div>
                        <label class="form-label">Role <span class="text-danger">*</span></label>
                        <select id="cu_Role" class="form-select">
                            <option value="Admin">Admin</option>
                            <option value="SeniorAgent">Senior Agent</option>
                            <option value="Agent" selected>Agent</option>
                            <option value="Support">Support</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Link to Agent Code</label>
                        <select id="cu_AgentCode" class="form-select">
                            <option value="">— None —</option>
                        </select>
                        <small class="text-muted">
                            Links this login to an Agent Profile
                        </small>
                    </div>
                    <div>
                        <label class="form-label">Active</label>
                        <select id="cu_IsActive" class="form-select">
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="btnCreateUser" class="btn-ptc-primary">
                    <i class="bi bi-save"></i> Create User
                </button>
            </div>
        </div>
    </div>
</div>

<!-- RESET PASSWORD MODAL -->
<div class="modal fade" id="resetPasswordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-key"></i> Reset Password
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="rp_UserId" />
                <p>Resetting password for: <strong id="rp_Username"></strong></p>
                <div class="mb-3">
                    <label class="form-label">New Password <span class="text-danger">*</span></label>
                    <input type="password" id="rp_NewPassword" class="form-control"
                           placeholder="Minimum 8 characters" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="btnResetPassword" class="btn-ptc-primary">
                    <i class="bi bi-key"></i> Reset Password
                </button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        $(document).ready(function () {

            // ============================================================
            // USER GRID
            // ============================================================
            var grid = $("#user_grid").kendoGrid({
                dataSource: {
                    transport: {
                        read: {
                            url  : '@Url.Action("UsersRead", "Security")',
                            type : 'POST'
                        },
                        parameterMap: function (data, operation) {
                            var token = $('input[name="__RequestVerificationToken"]').val();
                            if (operation === 'read') {
                                return {
                                    page      : data.page,
                                    pageSize  : data.pageSize,
                                    searchText: $('#filterSearchText').val(),
                                    __RequestVerificationToken: token
                                };
                            }
                            return $.extend({}, data, { __RequestVerificationToken: token });
                        }
                    },
                    schema: {
                        data: 'Data', total: 'Total', errors: 'Errors',
                        model: {
                            id: 'UserId',
                            fields: {
                                UserId          : { type: 'string' },
                                UserName        : { type: 'string' },
                                FullName        : { type: 'string' },
                                Email           : { type: 'string' },
                                IsActive        : { type: 'boolean' },
                                IsLockedOut     : { type: 'boolean' },
                                Roles           : { type: 'string' },
                                LinkedAgentCode : { type: 'string' }
                            }
                        }
                    },
                    pageSize: 15, serverPaging: true
                },
                pageable : { pageSize: 15, pageSizes: [15, 30], info: true },
                sortable : false, scrollable: true, height: 500,
                columns  : [
                    {
                        field: 'UserName',
                        title: 'Username',
                        width: 150,
                        template: function (item) {
                            return '<strong>' + kendo.htmlEncode(item.UserName) + '</strong>'
                                + (item.LinkedAgentCode
                                    ? '<br/><small class="text-muted">'
                                    + kendo.htmlEncode(item.LinkedAgentCode) + '</small>'
                                    : '');
                        }
                    },
                    { field: 'FullName', title: 'Full Name', width: 200 },
                    { field: 'Email',    title: 'Email',     width: 220 },
                    {
                        field: 'Roles',
                        title: 'Role',
                        width: 130,
                        template: function (item) {
                            return item.Roles
                                ? '<span class="badge-status badge-active">'
                                + kendo.htmlEncode(item.Roles) + '</span>'
                                : '<span class="text-muted">—</span>';
                        }
                    },
                    {
                        field: 'IsActive',
                        title: 'Active',
                        width: 90,
                        template: function (item) {
                            return item.IsActive
                                ? '<span class="badge-status badge-active">Yes</span>'
                                : '<span class="badge-status badge-cancelled">No</span>';
                        }
                    },
                    {
                        field: 'IsLockedOut',
                        title: 'Locked',
                        width: 90,
                        template: function (item) {
                            return item.IsLockedOut
                                ? '<span class="badge-status badge-expired">Locked</span>'
                                : '<span class="text-muted">—</span>';
                        }
                    },
                    {
                        title   : 'Actions',
                        width   : 200,
                        sortable: false,
                        template: function (item) {
                            var html = '';
                            // Toggle Active
                            html += '<button type="button" '
                                + 'class="btn btn-sm btn-outline-'
                                + (item.IsActive ? 'warning' : 'success')
                                + ' btn-toggle-active me-1" '
                                + 'data-id="' + item.UserId + '" '
                                + 'title="' + (item.IsActive ? 'Deactivate' : 'Activate') + '">'
                                + '<i class="bi bi-'
                                + (item.IsActive ? 'pause-circle' : 'play-circle')
                                + '"></i></button>';

                            // Unlock (only show if locked)
                            if (item.IsLockedOut) {
                                html += '<button type="button" '
                                    + 'class="btn btn-sm btn-outline-info btn-unlock me-1" '
                                    + 'data-id="' + item.UserId + '" '
                                    + 'data-name="' + kendo.htmlEncode(item.UserName) + '" '
                                    + 'title="Unlock Account">'
                                    + '<i class="bi bi-unlock"></i></button>';
                            }

                            // Reset Password
                            html += '<button type="button" '
                                + 'class="btn btn-sm btn-outline-secondary btn-reset-pwd" '
                                + 'data-id="' + item.UserId + '" '
                                + 'data-name="' + kendo.htmlEncode(item.UserName) + '" '
                                + 'title="Reset Password">'
                                + '<i class="bi bi-key"></i></button>';

                            return html;
                        }
                    }
                ]
            }).data("kendoGrid");

            grid.bind('dataBound', function () {
                $('#recordCount').text(this.dataSource.total() + ' records');
            });

            $('#btnSearch').on('click', function () { grid.dataSource.page(1); });
            $('#btnClearFilter').on('click', function () {
                $('#filterSearchText').val('');
                grid.dataSource.page(1);
            });
            $('#filterSearchText').on('keypress', function (e) {
                if (e.which === 13) { $('#btnSearch').click(); }
            });

            // ============================================================
            // LOAD UNLINKED AGENT PROFILES for Create User modal
            // ============================================================
            function loadUnlinkedAgents() {
                $.get('@Url.Action("AgentProfilesRead", "Security")',
                    { page: 1, pageSize: 100,
                      __RequestVerificationToken:
                        $('input[name="__RequestVerificationToken"]').val() })
                .done(function (res) {
                    if (res && res.Data) {
                        var sel = $('#cu_AgentCode');
                        sel.empty().append('<option value="">— None —</option>');
                        $.each(res.Data, function (i, a) {
                            if (!a.IsLinkedToLogin) {
                                sel.append($('<option>', {
                                    value: a.AgentCode,
                                    text : a.AgentCode + ' — ' + a.FullName
                                }));
                            }
                        });
                    }
                });
            }

            $('#btnNewUser').on('click', function () {
                // Clear form
                $('#cu_Username,#cu_FullName,#cu_Email,#cu_Password').val('');
                $('#cu_Role').val('Agent');
                $('#cu_IsActive').val('true');
                loadUnlinkedAgents();
                new bootstrap.Modal(document.getElementById('createUserModal')).show();
            });

            // ============================================================
            // CREATE USER
            // ============================================================
            $('#btnCreateUser').on('click', function () {
                var payload = {
                    UserName : $('#cu_Username').val(),
                    FullName : $('#cu_FullName').val(),
                    Email    : $('#cu_Email').val(),
                    Password : $('#cu_Password').val(),
                    Role     : $('#cu_Role').val(),
                    AgentCode: $('#cu_AgentCode').val(),
                    IsActive : $('#cu_IsActive').val(),
                    __RequestVerificationToken:
                        $('input[name="__RequestVerificationToken"]').val()
                };

                if (!payload.UserName || !payload.FullName ||
                    !payload.Email || !payload.Password) {
                    KSwal.warning('Username, Full Name, Email, and Password are required.');
                    return;
                }

                $.post('@Url.Action("CreateUser", "Security")', payload)
                    .done(function (res) {
                        if (res.success) {
                            bootstrap.Modal.getInstance(
                                document.getElementById('createUserModal')).hide();
                            KSwal.success(res.message);
                            grid.dataSource.read();
                        } else {
                            KSwal.error(res.message);
                        }
                    });
            });

            // ============================================================
            // TOGGLE ACTIVE
            // ============================================================
            $("#user_grid").on("click", ".btn-toggle-active", function () {
                var userId = $(this).data('id');
                var action = $(this).hasClass('btn-outline-warning') ? 'deactivate' : 'activate';

                KSwal.confirm('Are you sure you want to ' + action + ' this user?', 'Confirm')
                    .then(function (r) {
                        if (!r.isConfirmed) return;
                        $.post('@Url.Action("ToggleUserActive", "Security")', {
                            UserId: userId,
                            __RequestVerificationToken:
                                $('input[name="__RequestVerificationToken"]').val()
                        }).done(function (res) {
                            if (res.Errors) KSwal.error(res.Errors.error.errors[0]);
                            else {
                                KSwal.success('User ' + action + 'd.');
                                grid.dataSource.read();
                            }
                        });
                    });
            });

            // ============================================================
            // UNLOCK USER
            // ============================================================
            $("#user_grid").on("click", ".btn-unlock", function () {
                var userId   = $(this).data('id');
                var userName = $(this).data('name');

                KSwal.confirm('Unlock account for ' + userName + '?', 'Unlock Account')
                    .then(function (r) {
                        if (!r.isConfirmed) return;
                        $.post('@Url.Action("UnlockUser", "Security")', {
                            UserId: userId,
                            __RequestVerificationToken:
                                $('input[name="__RequestVerificationToken"]').val()
                        }).done(function (res) {
                            if (res.Errors) KSwal.error(res.Errors.error.errors[0]);
                            else {
                                KSwal.success(res.message);
                                grid.dataSource.read();
                            }
                        });
                    });
            });

            // ============================================================
            // RESET PASSWORD
            // ============================================================
            $("#user_grid").on("click", ".btn-reset-pwd", function () {
                $('#rp_UserId').val($(this).data('id'));
                $('#rp_Username').text($(this).data('name'));
                $('#rp_NewPassword').val('');
                new bootstrap.Modal(document.getElementById('resetPasswordModal')).show();
            });

            $('#btnResetPassword').on('click', function () {
                var payload = {
                    UserId     : $('#rp_UserId').val(),
                    NewPassword: $('#rp_NewPassword').val(),
                    __RequestVerificationToken:
                        $('input[name="__RequestVerificationToken"]').val()
                };

                if (!payload.NewPassword || payload.NewPassword.length < 8) {
                    KSwal.warning('New password must be at least 8 characters.'); return; }

                $.post('@Url.Action("ResetPassword", "Security")', payload)
                    .done(function (res) {
                        if (res.success) {
                            bootstrap.Modal.getInstance(
                                document.getElementById('resetPasswordModal')).hide();
                            KSwal.success(res.message);
                        } else {
                            KSwal.error(res.message);
                        }
                    });
            });

        });
    </script>
}